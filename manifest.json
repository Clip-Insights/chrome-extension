{
  "manifest_version": 3,
  "name": "Clip Insights",
  "version": "3.0.0",
  "description": "Clip Insights: Capture video screenshots, add notes, extract key points, and save summaries as PDFs.",
  "permissions": [
    "scripting"
  ],
  "action": {
  "default_icon": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "default_popup_width": 400,
  "default_popup_height": 600
},
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "libs/jspdf.umd.min.js",
        "libs/pdfobject.min.js",
        "popup.html",
        "plus.png",
        "camera.png",
        "logo1.jpg"
      ],
      "matches": [
        "https://www.youtube.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "libs/jspdf.umd.min.js",
        "libs/pdfobject.min.js",
        "database.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "options_ui": {
    "open_in_tab": true
  }
}
